# ============================================================
# Indian Financial Intelligence MCP Server — Environment Config
# ============================================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the server to start.
# Lines marked [OPTIONAL] enable additional features.

# --- LLM Provider ---
# [REQUIRED] Sign up: https://platform.openai.com/signup
OPENAI_API_KEY=sk-your-openai-key-here

# --- Financial Data APIs ---
# Angel One SmartAPI — https://smartapi.angelone.in/docs
# App dashboard: API Key + Secret Key; login also needs client code, password, TOTP.
ANGEL_ONE_API_KEY=your-angel-one-api-key
ANGEL_ONE_API_SECRET=your-angel-one-secret-key
ANGEL_ONE_CLIENT_CODE=your-client-code
ANGEL_ONE_PASSWORD=your-password
ANGEL_ONE_TOTP_SECRET=your-totp-secret

# [OPTIONAL] Sign up: https://www.alphavantage.co/support/#api-key (free, 25 req/day)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# [OPTIONAL] Sign up: https://finnhub.io/register (free, 60 req/min)
FINNHUB_KEY=your-finnhub-key

# [OPTIONAL] Sign up: https://gnews.io/register (free, 100 req/day)
GNEWS_KEY=your-gnews-key

# --- Observability ---
# [OPTIONAL] Sign up: https://smith.langchain.com/ (free tier)
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=finint-mcp
LANGCHAIN_TRACING_V2=true

# --- Keycloak Auth Server ---
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=finint
KEYCLOAK_CLIENT_ID=finint-mcp
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finint
POSTGRES_USER=finint
POSTGRES_PASSWORD=finint_secure_pwd_2026

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MCP Server ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=10004
# Browser-visible URL for OAuth protected-resource metadata (RFC 9728)
OAUTH_RESOURCE_URL=http://localhost:10004

MCP_SERVER_URL=http://mcp-server:10004

# --- Frontend (host ports when using docker compose: Keycloak 10003, MCP 10004, app 10005) ---
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:10004
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:10003
NEXT_PUBLIC_KEYCLOAK_REALM=finint
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=finint-dashboard
NEXTAUTH_URL=http://localhost:10005
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production

# --- EC2 / registry (docker-compose.ec2.yml only) ---
DOCKERHUB_USER=your-dockerhub-user
W3_PUBLIC_HOST=your-ec2-public-ip-or-dns