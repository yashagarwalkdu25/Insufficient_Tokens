    },
    {
      "username": "analyst_user",
      "enabled": true,
      "email": "analyst@finint.dev",
      "emailVerified": true,
      "firstName": "Analyst",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "analyst123",
          "temporary": false
        }
      ],
      "realmRoles": ["analyst"]
    },
    {
      "username": "admin_user",
      "enabled": true,
      "email": "admin@finint.dev",
      "emailVerified": true,
