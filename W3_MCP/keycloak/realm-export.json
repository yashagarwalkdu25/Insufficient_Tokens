      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "analyst"]
    }
  ],

  "scopeMappings": [
    {
      "clientScope": "market:read",
      "roles": ["free", "premium", "analyst", "admin"]
    },
    {
      "clientScope": "mf:read",
      "roles": ["free", "premium", "analyst", "admin"]
    },
    {
      "clientScope": "news:read",
      "roles": ["free", "premium", "analyst", "admin"]
    },
    {
      "clientScope": "watchlist:read",
      "roles": ["free", "premium", "analyst", "admin"]
    },
    {
      "clientScope": "watchlist:write",
      "roles": ["free", "premium", "analyst", "admin"]
    },
    {
      "clientScope": "fundamentals:read",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "technicals:read",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "macro:read",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "portfolio:read",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "portfolio:write",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "filings:read",
      "roles": ["premium", "analyst", "admin"]
    },
    {
      "clientScope": "filings:deep",
      "roles": ["analyst", "admin"]
    },
    {
      "clientScope": "macro:historical",
      "roles": ["analyst", "admin"]
    },
    {
      "clientScope": "research:generate",
      "roles": ["analyst", "admin"]
    }
  ],

  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "rsa-generated",
        "providerId": "rsa-generated",
        "config": {
          "priority": ["100"],
          "algorithm": ["RS256"],
          "keySize": ["2048"]
        }
      }
    ]
  }
}
